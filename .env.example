# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit secrets.

# ── Database ─────────────────────────────────────────────────────────────────
# Password for PostgreSQL — also used by docker-compose.yml and martin-config.yaml.
POSTGRES_PASSWORD=devpassword

# PostgreSQL connection string (local dev — Docker exposes port 5432 to host)
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@localhost:5432/ttdb

# ── Martin tile server ────────────────────────────────────────────────────────
# Local dev: docker-compose.override.yml exposes Martin on localhost:3001
# Production: use the internal Docker/K8s service name (e.g. http://martin:3000)
MARTIN_INTERNAL_URL=http://localhost:3001

# ── Auth.js ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth (https://console.developers.google.com)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Microsoft Entra ID (https://portal.azure.com → App registrations)
# Verify exact variable names against the installed next-auth@beta version before use.
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
# Single tenant:  https://login.microsoftonline.com/{tenant-id}/v2.0
# Multi-tenant:   https://login.microsoftonline.com/common/v2.0
AUTH_MICROSOFT_ENTRA_ID_ISSUER=

# ── Access control ────────────────────────────────────────────────────────────
# Comma-separated list of allowed email domains for JIT provisioning.
# If unset, any authenticated email is accepted (suitable for local dev).
# Example: ALLOWED_EMAIL_DOMAINS=example.com,corp.example.com
ALLOWED_EMAIL_DOMAINS=
