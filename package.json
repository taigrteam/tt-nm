{
  "name": "tt-nm",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @tt-nm/web dev",
    "build": "pnpm --filter @tt-nm/web build",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d",
    "db:logs": "docker compose logs -f"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
